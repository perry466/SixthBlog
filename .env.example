# SixthBlog 环境变量配置（可选）
# 直接 docker compose up -d 即可运行，无需创建 .env 文件
# 此文件仅用于需要自定义配置时参考，复制为 docker/.env 并修改

# Django（可选，Docker 默认 DEBUG=false, ALLOWED_HOSTS=*）
# DJANGO_SECRET_KEY=你的随机密钥
# DJANGO_DEBUG=False
# ALLOWED_HOSTS=*

# 数据库（可选，Docker 默认使用下方值）
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=sixth_db
# DB_USER=Sixth_user
# DB_PASSWORD=你的密码
# DB_HOST=db
# DB_PORT=3306

# Docker Compose 用（可选）
# MYSQL_ROOT_PASSWORD=你的root密码

# 以下两项 Docker 同源部署无需设置，留空即可
# CORS_ORIGINS=
# CSRF_TRUSTED_ORIGINS=
