# SixthBlog 环境变量配置（可选）
# 推荐使用 setup.sh 交互式配置：bash setup.sh
# 或复制为 docker/.env 后手动修改
#
# docker compose 会优先读取 docker/.env 中的变量，
# 未设置时使用 docker-compose.yml 中的默认值。

# Django（可选，Docker 默认 DEBUG=false, ALLOWED_HOSTS=*）
# DJANGO_SECRET_KEY=你的随机密钥
# DJANGO_DEBUG=False
# ALLOWED_HOSTS=*

# 数据库（通过 setup.sh 配置，或手动填写）
# DB_NAME=sixth_db
# DB_USER=Sixth_user
# DB_PASSWORD=你的数据库用户密码
# DB_HOST=db
# DB_PORT=3306

# Docker Compose 用（通过 setup.sh 配置，或手动填写）
# MYSQL_ROOT_PASSWORD=你的MySQL_Root密码

# 以下两项 Docker 同源部署无需设置，留空即可
# CORS_ORIGINS=
# CSRF_TRUSTED_ORIGINS=
